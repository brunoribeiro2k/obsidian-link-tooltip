{
	"name": "obsidian-link-tooltip",
	"version": "0.1.0",
	"description": "Show hovered external link URLs in Obsidian Live Preview and source mode.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "npm run build && node --test test/is-external-url.test.mjs",
		"deploy": "npm run build && node scripts/deploy.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"codemirror",
		"link-tooltip"
	],
	"author": "Bruno Ribeiro",
	"license": "MIT",
	"devDependencies": {
		"@codemirror/language": "^6.11.0",
		"@codemirror/view": "^6.36.8",
		"builtin-modules": "^5.0.0",
		"esbuild": "^0.25.0",
		"obsidian": "^1.8.7",
		"typescript": "^5.8.2"
	}
}
